# Webhook URL for notifications
WEBHOOK_URL=https://example.com/webhook

# Schedule settings (cron format or simple time)
# Daily notification time (HH:MM format, 24-hour)
DAILY_NOTIFICATION_TIME=08:00

# Weekly notification day and time
# 0=Monday, 1=Tuesday, ..., 6=Sunday
WEEKLY_NOTIFICATION_DAY=0
WEEKLY_NOTIFICATION_TIME=09:00

# Path to meal image
MEAL_IMAGE_PATH=./meal_schedule.jpg
