# Mattermost Webhook URL
MATTERMOST_WEBHOOK_URL=https://your-mattermost-server.com/hooks/xxx

# Discord Webhook URL
DISCORD_WEBHOOK_URL=https://discord.com/api/webhooks/xxx/yyy

# 오늘의 노래 추천 Mattermost Webhook URL
MATTERMOST_TODAY_SONG_URL=https://your-mattermost-server.com/hooks/yyy

# 웰스토리 식단 크롤링 설정 (welplan.pmh.codes API 사용, 인증 불필요)
# 기본값: 멀티캠퍼스 (변경 필요 시에만 설정)
# WELSTORY_RESTAURANT_QUERY=멀티캠퍼스

# Google Cloud Document AI 설정 (OCR 방식 사용 시)
# 서비스 계정 JSON 키 전체 내용 (한 줄로)
GOOGLE_CLOUD_CREDENTIALS={"type":"service_account","project_id":"your-project-id","private_key_id":"...","private_key":"...","client_email":"...","client_id":"...","auth_uri":"...","token_uri":"...","auth_provider_x509_cert_url":"...","client_x509_cert_url":"..."}

# Google Cloud 프로젝트 ID
GOOGLE_CLOUD_PROJECT_ID=your-project-id

# Document AI Processor ID
GOOGLE_CLOUD_PROCESSOR_ID=your-processor-id

# Processor 위치 (us, eu, asia 등)
GOOGLE_CLOUD_LOCATION=us
